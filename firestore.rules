rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid in [
        "UID_ADMIN_1",
        "UID_ADMIN_2",
        "UID_ADMIN_3"
      ];
    }

    match /users/{userId}/quotes/{quoteId} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /stock/{docId} {
      allow read, write: if isAdmin();
    }

    match /inventory_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
