rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid in [
        "ZPxZusAiyfY6cf2LSn1ynP5A7rG3",
        "XolYJ2aOCdZPgiTg4WKVSOcRPmO2",
        "cNXpQsFClscsPGURl0gedehYcFo2"
      ];
    }

    function isOwnActivityLogCreate() {
      return isSignedIn()
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.user is string
        && request.resource.data.createdAt is int
        && request.resource.data.timestamp is string
        && request.resource.data.eventType is string
        && request.resource.data.system is string
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string
        && request.resource.data.details is string
        && request.resource.data.metadata is map;
    }

    function isOwnOrderRequestRead() {
      return isSignedIn() && resource.data.createdByUid == request.auth.uid;
    }

    function isOwnOrderRequestCreate() {
      return isSignedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByEmail is string
        && request.resource.data.quoteOwnerUid == request.auth.uid
        && request.resource.data.quoteId is string
        && request.resource.data.quoteNumber is string
        && request.resource.data.quoteVersion is int
        && request.resource.data.retailerId is string
        && request.resource.data.retailerName is string
        && request.resource.data.retailerEmail is string
        && request.resource.data.customerName is string
        && request.resource.data.company is string
        && request.resource.data.reference is string
        && request.resource.data.customerReference is string
        && request.resource.data.selectedLines is list
        && (request.resource.data.totalSek is int || request.resource.data.totalSek is float)
        && request.resource.data.status in ['new', 'reviewing', 'completed']
        && request.resource.data.createdAtMs is int
        && request.resource.data.updatedAtMs is int
        && request.resource.data.statusUpdatedByUid == request.auth.uid
        && request.resource.data.statusUpdatedByEmail is string;
    }

    match /users/{userId}/quotes/{quoteId} {
      allow read, create, update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/quotes/{quoteId}/revisions/{revisionId} {
      allow read, create, update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /stock/{docId} {
      allow read, write: if isAdmin();
    }

    match /inventory_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isOwnActivityLogCreate();
    }

    match /quote_counters/{dateKey} {
      allow read, create, update: if isSignedIn();
    }

    match /users/{userId}/templates/{templateId} {
      allow read, create, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /planner_projects/{projectId} {
      allow read, write: if isAdmin();
    }

    match /retailers/{retailerId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email == resource.data.email;
    }

    match /order_requests/{requestId} {
      allow create: if isOwnOrderRequestCreate();
      allow read: if isAdmin() || isOwnOrderRequestRead();
      allow update: if isAdmin();
    }

    match /retailer_line_documents/{lineId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Allow admins to read all templates via collectionGroup queries
    match /{path=**}/templates/{templateId} {
      allow read: if isAdmin();
    }

    // Allow admins to read all quotes via collectionGroup queries
    match /{path=**}/quotes/{quoteId} {
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
